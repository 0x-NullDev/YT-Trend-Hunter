# =============================================================================
# YT Trend Hunter - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# =============================================================================
# Application
# =============================================================================
APP_NAME=YT Trend Hunter
APP_VERSION=1.0.0
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-a-random-secret-key
APP_HOST=0.0.0.0
APP_PORT=8000
APP_CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# =============================================================================
# Database - PostgreSQL
# =============================================================================
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/yt_trend_hunter
DATABASE_SYNC_URL=postgresql://postgres:postgres@localhost:5432/yt_trend_hunter
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40

# =============================================================================
# Redis - Cache & Task Queue
# =============================================================================
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=300
REDIS_CACHE_PREFIX=ytth:

# =============================================================================
# Celery - Task Queue
# =============================================================================
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_ACCEPT_CONTENT=json
CELERY_TIMEZONE=UTC
CELERY_TASK_TRACK_STARTED=true
CELERY_TASK_TIME_LIMIT=3600
CELERY_TASK_SOFT_TIME_LIMIT=3000

# =============================================================================
# Elasticsearch - Search Engine
# =============================================================================
ELASTICSEARCH_HOSTS=http://localhost:9200
ELASTICSEARCH_INDEX_PREFIX=ytth_
ELASTICSEARCH_SHARDS=3
ELASTICSEARCH_REPLICAS=1

# =============================================================================
# YouTube Data API v3
# =============================================================================
YOUTUBE_API_KEY=your-youtube-api-key-here
YOUTUBE_API_QUOTA_LIMIT=10000
YOUTUBE_API_QUOTA_SAFETY_MARGIN=0.8
YOUTUBE_API_MAX_RESULTS=50
YOUTUBE_API_MAX_COMMENTS=500
YOUTUBE_API_RATE_LIMIT=1.0

# =============================================================================
# Google Trends
# =============================================================================
GOOGLE_TRENDS_ENABLED=true
GOOGLE_TRENDS_HL=en-US
GOOGLE_TRENDS_TZ=360
GOOGLE_TRENDS_GEO=US

# =============================================================================
# Reddit API
# =============================================================================
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_USER_AGENT=YT_Trend_Hunter/1.0
REDDIT_RATE_LIMIT=1.0

# =============================================================================
# News API
# =============================================================================
NEWS_API_KEY=your-news-api-key
NEWS_API_RATE_LIMIT=1.0

# =============================================================================
# AI Providers
# =============================================================================

# DeepSeek
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_MAX_TOKENS=4096
DEEPSEEK_TEMPERATURE=0.7

# OpenAI
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.7

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-3-opus-20240229
ANTHROPIC_MAX_TOKENS=4096
ANTHROPIC_TEMPERATURE=0.7

# Ollama (Local)
OLLAMA_API_BASE=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_MAX_TOKENS=4096
OLLAMA_TEMPERATURE=0.7

# Default AI Provider
AI_DEFAULT_PROVIDER=deepseek

# =============================================================================
# Reporting
# =============================================================================
REPORT_OUTPUT_DIR=./reports
REPORT_MAX_RETENTION_DAYS=90
REPORT_AUTO_GENERATE=true

# =============================================================================
# Automation & Scheduling
# =============================================================================
SCHEDULER_ENABLED=true
SCHEDULER_GLOBAL_SCAN_INTERVAL_HOURS=24
SCHEDULER_NICHE_SCAN_INTERVAL_HOURS=12
SCHEDULER_TREND_REFRESH_INTERVAL_HOURS=6
SCHEDULER_COMPETITOR_SCAN_INTERVAL_HOURS=24
SCHEDULER_COMMENT_SCAN_INTERVAL_HOURS=48

# =============================================================================
# Alerts & Notifications
# =============================================================================
ALERTS_ENABLED=true
ALERTS_EMAIL_ENABLED=false
ALERTS_SLACK_ENABLED=false
ALERTS_DISCORD_ENABLED=false
ALERTS_SLACK_WEBHOOK_URL=
ALERTS_DISCORD_WEBHOOK_URL=
ALERTS_SMTP_HOST=
ALERTS_SMTP_PORT=587
ALERTS_SMTP_USER=
ALERTS_SMTP_PASSWORD=
ALERTS_EMAIL_FROM=
ALERTS_EMAIL_TO=

# =============================================================================
# Rate Limiting
# =============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=./logs/yt_trend_hunter.log

# =============================================================================
# Frontend
# =============================================================================
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_GA_ID=
